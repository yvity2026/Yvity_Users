# YVITY Gold — copy to .env.local and fill keys from Supabase Dashboard:
# https://supabase.com/dashboard/project/akwvvhntxbhjyixaxhpv/settings/api

# --- Supabase (hosted project) ---
NEXT_PUBLIC_SUPABASE_URL=https://akwvvhntxbhjyixaxhpv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_publishable_or_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_here

# App URL (local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3002
NEXT_PUBLIC_APP_URL=http://localhost:3002

# --- Razorpay (test keys for dev) ---
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Required for Yvity_Admin local integration (shared .data with Admin dashboard)
YVITY_FORCE_LOCAL_DATA=true

# --- OTP delivery (production) ---
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_API_TOKEN=  # alias for WHATSAPP_ACCESS_TOKEN
# Optional: use {code} placeholder
# WHATSAPP_OTP_MESSAGE=Your YVITY code is {code}. Valid for 10 minutes.
RESEND_API_KEY=
YVITY_EMAIL_FROM=YVITY <onboarding@yvity.in>
# Local dev only — never set true in Vercel production
# YVITY_ALLOW_DEMO_OTP=true
